// 21. Producer Consumer System (Restaurant)
class Restaurant {
    private boolean foodReady = false;

    public synchronized void prepareFood() {
        try {
            while (foodReady)
                wait();
            System.out.println("Chef prepared food");
            foodReady = true;
            notify();
        } catch (Exception e) {}
    }

    public synchronized void serveFood() {
        try {
            while (!foodReady)
                wait();
            System.out.println("Waiter served food");
            foodReady = false;
            notify();
        } catch (Exception e) {}
    }
}

class Chef extends Thread {
    Restaurant r;
    Chef(Restaurant r) { this.r = r; }

    public void run() {
        for (int i = 0; i < 3; i++)
            r.prepareFood();
    }
}

class Waiter extends Thread {
    Restaurant r;
    Waiter(Restaurant r) { this.r = r; }

    public void run() {
        for (int i = 0; i < 3; i++)
            r.serveFood();
    }
}

// 22. Banking System
class BankingSystem {
    private int balance = 1000;

    public void withdraw(String user, int amount) {
        synchronized (this) {
            if (balance >= amount) {
                System.out.println(user + " is withdrawing " + amount);
                balance -= amount;
                System.out.println("Remaining balance: " + balance);
            } else {
                System.out.println(user + " - Insufficient balance");
            }
        }
    }
}

class User extends Thread {
    BankingSystem bank;
    String name;
    int amount;

    User(BankingSystem bank, String name, int amount) {
        this.bank = bank;
        this.name = name;
        this.amount = amount;
    }

    public void run() {
        bank.withdraw(name, amount);
    }
}

// 23. Chat Application
class ChatApplication {
    public void sendMessage() {
        for (int i = 1; i <= 3; i++) {
            System.out.println("Sending message " + i);
            try { Thread.sleep(500); } catch (Exception e) {}
        }
    }

    public void receiveMessage() {
        for (int i = 1; i <= 3; i++) {
            System.out.println("Receiving message " + i);
            try { Thread.sleep(500); } catch (Exception e) {}
        }
    }
}

class Sender extends Thread {
    ChatApplication chat;
    Sender(ChatApplication chat) { this.chat = chat; }

    public void run() {
        chat.sendMessage();
    }
}

class Receiver extends Thread {
    ChatApplication chat;
    Receiver(ChatApplication chat) { this.chat = chat; }

    public void run() {
        chat.receiveMessage();
    }
}

// Main Class
public class MultiThreadingPrograms {
    public static void main(String[] args) {

        // Producer-Consumer
        Restaurant r = new Restaurant();
        new Chef(r).start();
        new Waiter(r).start();

        // Banking System
        BankingSystem bank = new BankingSystem();
        new User(bank, "User1", 500).start();
        new User(bank, "User2", 700).start();

        // Chat Application
        ChatApplication chat = new ChatApplication();
        new Sender(chat).start();
        new Receiver(chat).start();
    }
}
