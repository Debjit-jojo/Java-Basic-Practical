// Main class to run all
public class MainProgram {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        // ATM Withdrawal
        ATMWithdrawal atm = new ATMWithdrawal();
        System.out.print("Enter balance: ");
